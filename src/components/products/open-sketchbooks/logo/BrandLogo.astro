---
interface Props {
  href?: string;
  label?: string;
}

const {
  href = "/",
  label = "Open Sketchbook",
} = Astro.props;
---

<a href={href} class="brand-logo" aria-label={label}>
  <span class="brand-logo__mark" aria-hidden="true">
    <img
      src="/images/icon-star.png"
      alt=""
      class="brand-logo__img"
      loading="eager"
      decoding="async"
    />
  </span>

  <span class="brand-logo__text">
    <slot>Open Sketchbook</slot>
  </span>
</a>

<style>
  .brand-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;

    color: inherit;

    /* ❗ убираем ВСЕ эффекты ссылки */
    text-decoration: none;
    border-bottom: none;
  }

  /* если глобально вдруг используется ::after underline */
  .brand-logo::after {
    content: none;
  }

  /* hover не должен превращать в ссылку */
  .brand-logo:hover {
    color: inherit;
    border-bottom: none;
  }

  /* focus тоже без подчеркивания */
  .brand-logo:focus-visible {
    outline: none;
    border-bottom: none;
  }

  /* ======================================================
     MARK
  ====================================================== */

  .brand-logo__mark {
    width: 1.6rem;
    height: 1.6rem;

    display: inline-flex;
    align-items: center;
    justify-content: center;

    transform: rotate(-6deg);
    flex-shrink: 0;
  }

  .brand-logo__svg {
    width: 100%;
    height: 100%;
    display: block;
    overflow: visible;
  }

  .brand-logo__svg polygon {
    fill: var(--brand-mark-color, var(--color-paper-white));
    stroke: var(--brand-mark-stroke, var(--color-text));
    stroke-width: 2.4;
    stroke-linejoin: round;
  }

  /* ======================================================
     TEXT
  ====================================================== */

  .brand-logo__text {
    font-weight: 700;
    font-size: 1rem;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .brand-logo__img {
  width: 50px;
  height: 50px;
  display: block;

  object-fit: contain;
}
</style>
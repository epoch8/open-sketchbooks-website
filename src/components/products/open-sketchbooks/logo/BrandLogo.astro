---
interface Props {
  href?: string;
  label?: string;
}

const {
  href = "/",
  label = "Open Sketchbooks",
} = Astro.props;
---

<a href={href} class="brand-logo" aria-label={label}>
  <span class="brand-logo__mark" aria-hidden="true">
    <svg
      viewBox="0 0 72 72"
      class="brand-logo__svg"
      role="img"
      focusable="false"
    >
      <polygon
        points="36,5 41,21 57,11 48,28 67,33 48,39 56,58 40,49 35,67 29,49 13,59 21,40 5,34 22,28 13,13 30,22"
      />
    </svg>
  </span>

  <span class="brand-logo__text">
    <slot>Open Sketchbooks</slot>
  </span>
</a>

<style>
  .brand-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
    color: inherit;
  }

  .brand-logo__mark {
    width: 1.6rem;
    height: 1.6rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transform: rotate(-6deg);
    flex-shrink: 0;
  }

  .brand-logo__svg {
    width: 100%;
    height: 100%;
    display: block;
    overflow: visible;
  }

  .brand-logo__svg polygon {
    fill: var(--brand-mark-color, var(--color-paper-white));
    stroke: var(--brand-mark-stroke, var(--color-text));
    stroke-width: 2.4;
    stroke-linejoin: round;
  }

  .brand-logo__text {
    font-weight: 700;
    font-size: 1rem;
    line-height: 1;
    letter-spacing: -0.02em;
  }
</style>
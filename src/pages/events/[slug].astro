---
import InternalLayout from "@/layouts/InternalLayout.astro";
import { SEOBase } from "@/content/template/seo/seo";
import type { SEOConfig } from "@/lib/seo/types";


import { getCollection, getEntry } from "astro:content";

import {
  mainNav,
  footerNav,
  footerMeta,
} from "@/content/template/navigation/navigation";

import BrandLogo from "@/components/products/open-sketchbooks/logo/BrandLogo.astro";

/* ================================
   STATIC PATHS
================================ */

export async function getStaticPaths() {
  const events = await getCollection("events");

  return events.map((event) => ({
    params: {
      slug: event.slug, // 👈 filesystem slug
    },
    props: {
      event,
    },
  }));
}

/* ================================
   PROPS
================================ */

const { event } = Astro.props;

/* ================================
   TYPE GUARD
================================ */

function isDefined<T>(value: T | undefined): value is T {
  return value !== undefined;
}

/* ================================
   RELATED ARTISTS
================================ */

const artistEntries = (
  await Promise.all(
    (event.data.artists || []).map(async (slug) => {
      const entry = await getEntry("artists", slug);

      if (!entry) {
        console.warn(`Missing artist: ${slug}`);
      }

      return entry;
    })
  )
).filter(isDefined);

/* ================================
   MARKDOWN
================================ */

const { Content } = await event.render();

/* ================================
   SEO
================================ */

const pageSEO: Partial<SEOConfig> = {
  title: `${event.data.title} – Open Sketchbooks`,
  description:
    event.data.description ||
    "Sketchbook event from Open Sketchbook community.",

  canonical: `https://open-sketchbook.place/events/${event.slug}`,

  og: {
    type: "article",
    image: "/og/events.jpg",
    imageAlt: "Events – Open Sketchbooks",
  },

  twitter: {
    card: "summary_large_image",
    image: "/og/events.jpg",
  },
};

/* ================================
   DATE
================================ */

const formattedDate = new Date(event.data.date).toLocaleDateString("en", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<InternalLayout
  baseSEO={SEOBase}
  pageSEO={pageSEO}
  navItems={mainNav}
  footerSections={footerNav}
  footerMeta={footerMeta}
  logo={BrandLogo}
>

  <section class="section">
    <div class="container flow">

      {/* HEADER */}
      <header class="hero-header">

        <div class="hero-header__left">
          <h1>{event.data.title}</h1>

          <p class="hero-header__meta">
            {formattedDate} · {event.data.location}
          </p>
        </div>

        <div class="hero-header__right">
          <button class="hero-cta" data-scroll-to-rsvp>
            Save me a spot
          </button>
        </div>

      </header>

      {/* COVER */}
      {event.data.cover && (
        <img
          src={event.data.cover}
          alt={event.data.title}
          style="width:100%; border-radius:12px;"
        />
      )}

      {/* CONTENT */}
      <article class="flow">
        <Content />
      </article>

    </div>
  </section>

  {/* ================================
     ARTISTS
  ================================= */}

  {artistEntries.length > 0 && (
    <section class="section">
      <div class="container flow">

        <h2>Artists</h2>
        <p>Featuring works by:</p>

        <ul
          style="
            columns: 220px;
            column-gap: 24px;
            list-style: none;
            padding: 0;
            margin: 0;
          "
        >
          {artistEntries.map((artist) => (
            <li style="break-inside: avoid; margin-bottom: 8px;">
              <a href={`/artists/${artist.slug}`}>
                {artist.data.title}
              </a>
            </li>
          ))}
        </ul>

      </div>
    </section>
  )}

  {/* ================================
     CTA
  ================================= */}

<section class="section" id="rsvp">
  <div class="container">
    <div class="rsvp">

      <div class="rsvp__header">
        <h2 class="rsvp__title">
          Can't wait to see you there!
        </h2>
      </div>

      <div class="rsvp__body">

        <p class="rsvp__note">
          Leave your email and we’ll remind you before the event. No spam.
        </p>

        <div id="mlb2-39245507" class="rsvp__form ml-subscribe-form">

          <div class="row-form">

          <form
            class="ml-block-form"
            action="https://assets.mailerlite.com/jsonp/1909692/forms/183455915355146175/subscribe"
            method="post"
          >
            <input
              type="email"
              name="fields[email]"
              placeholder="your email"
              required
              class="rsvp__input"
              autocomplete="email"
            />

            <button type="submit" class="rsvp__button">
              Remind me
            </button>

            <input type="hidden" name="ml-submit" value="1" />
            <input type="hidden" name="anticsrf" value="true" />
          </form>

          </div>

          <!-- ❗ БЕЗ display:none -->
          <div class="row-success rsvp__success">
            <h4 class="rsvp__success-title">You're on the list ✨</h4>
            <p class="rsvp__success-text">We’ll remind you before the event</p>
          </div>

        </div>

      </div>

    </div>
  </div>
</section>

</InternalLayout>

<script is:inline>
  function ml_webform_success_39245507() {
    const container = document.getElementById('mlb2-39245507');

    if (container instanceof HTMLElement) {
      container.classList.add('is-success');
    }
  }
</script>

<script
  is:inline
  src="https://groot.mailerlite.com/js/w/webforms.min.js"
></script>

<script is:inline>
  document.querySelectorAll('[data-scroll-to-rsvp]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const el = document.getElementById('rsvp');
      if (el) {
        el.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    });
  });
</script>
---
import InternalLayout from "@/layouts/InternalLayout.astro";
import { SEOBase } from "@/content/template/seo/seo";
import type { SEOConfig } from "@/lib/seo/types";


import { getCollection, getEntry } from "astro:content";

import {
  mainNav,
  footerNav,
  footerMeta,
} from "@/content/template/navigation/navigation";

import BrandLogo from "@/components/products/open-sketchbooks/logo/BrandLogo.astro";

/* ================================
   STATIC PATHS
================================ */

export async function getStaticPaths() {
  const events = await getCollection("events");

  return events.map((event) => ({
    params: {
      slug: event.slug, // 👈 filesystem slug
    },
    props: {
      event,
    },
  }));
}

/* ================================
   PROPS
================================ */

const { event } = Astro.props;

/* ================================
   TYPE GUARD
================================ */

function isDefined<T>(value: T | undefined): value is T {
  return value !== undefined;
}

/* ================================
   RELATED ARTISTS
================================ */

const artistEntries = (
  await Promise.all(
    (event.data.artists || []).map(async (slug) => {
      const entry = await getEntry("artists", slug);

      if (!entry) {
        console.warn(`Missing artist: ${slug}`);
      }

      return entry;
    })
  )
).filter(isDefined);

/* ================================
   MARKDOWN
================================ */

const { Content } = await event.render();

/* ================================
   SEO
================================ */

const pageSEO: Partial<SEOConfig> = {
  title: `${event.data.title} — Open Sketchbooks`,
  description:
    event.data.description ||
    "Sketchbook event from Open Sketchbook community.",

  canonical: `https://open-sketchbook.place/events/${event.slug}`,

  og: {
    type: "article",
    image: "/og/events.jpg",
    imageAlt: "Events – Open Sketchbooks",
  },

  twitter: {
    card: "summary_large_image",
    image: "/og/events.jpg",
  },
};

/* ================================
   DATE
================================ */

const formattedDate = new Date(event.data.date).toLocaleDateString("en", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<InternalLayout
  baseSEO={SEOBase}
  pageSEO={pageSEO}
  navItems={mainNav}
  footerSections={footerNav}
  footerMeta={footerMeta}
  logo={BrandLogo}
>

  <section class="section">
    <div class="container flow">

      {/* HEADER */}
      <header class="flow">
        <h1>{event.data.title}</h1>

        <p>
          {formattedDate} · {event.data.location}
        </p>
      </header>

      {/* COVER */}
      {event.data.cover && (
        <img
          src={event.data.cover}
          alt={event.data.title}
          style="width:100%; border-radius:12px;"
        />
      )}

      {/* CONTENT */}
      <article class="flow">
        <Content />
      </article>

    </div>
  </section>

  {/* ================================
     ARTISTS
  ================================= */}

  {artistEntries.length > 0 && (
    <section class="section">
      <div class="container flow">

        <h2>Artists</h2>
        <p>Featuring works by:</p>

        <ul
          style="
            columns: 220px;
            column-gap: 24px;
            list-style: none;
            padding: 0;
            margin: 0;
          "
        >
          {artistEntries.map((artist) => (
            <li style="break-inside: avoid; margin-bottom: 8px;">
              <a href={`/artists/${artist.id}`}>
                {artist.data.title}
              </a>
            </li>
          ))}
        </ul>

      </div>
    </section>
  )}

  {/* ================================
     CTA
  ================================= */}

<section class="section">
  <div class="container">

    <div class="rsvp">

      <div class="rsvp__header">
        <h2 class="rsvp__title">
          Can't wait to see you there!
        </h2>
      </div>

      <div class="rsvp__body">

                <!-- NOTE -->
        <p class="rsvp__note">
          Leave your email and we’ll remind you before the event. No spam.
        </p>

        <!-- FORM -->
        <form 
            id="rsvp-form" 
            class="rsvp__form"
            data-event="tbilisi-sketchbook-exhibition-spring-2026"
            data-group="183455938539161323">
          <input 
            type="email" 
            name="email" 
            placeholder="your email"
            required
            class="rsvp__input"
          />

          <button type="submit" class="rsvp__button">
            Remind me
          </button>
        </form>



        <!-- SUCCESS -->
        <div id="rsvp-success" class="rsvp__success" style="display:none;">
          <h4 class="rsvp__success-title">
            You're on the list ✨
          </h4>
          <p class="rsvp__success-text">
            We’ll remind you before the event
          </p>
        </div>

      </div>

    </div>

  </div>
</section>



</InternalLayout>

<script>
  const form = document.getElementById('rsvp-form');
  const success = document.getElementById('rsvp-success');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const email = form.email.value;
    const group = form.dataset.group;
    const artist = form.dataset.artist;
    const event = form.dataset.event;

    const payload = {
      email,
      ...(group ? { group } : {}),
      ...(artist ? { artist } : {}),
      ...(event ? { event } : {}),
    };

    const res = await fetch('/api/subscribe', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });

    if (res.ok) {
      form.style.display = 'none';
      success.style.display = 'block';
    } else {
      alert('Something went wrong');
    }
  });
</script>
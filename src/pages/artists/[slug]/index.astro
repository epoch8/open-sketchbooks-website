---
import InternalLayout from "@/layouts/InternalLayout.astro";
import Gallery from "@/components/blocks/gallery/Gallery.astro";
import CardGrid from "@/components/blocks/card-grid/CardGrid.astro";
import CardGridItem from "@/components/blocks/card-grid/CardGridItem.astro";

import { getCollection } from "astro:content";

import {
  mainNav,
  footerNav,
  footerMeta,
} from "@/content/template/navigation/navigation";

import BrandLogo from "@/components/products/open-sketchbooks/logo/BrandLogo.astro";

import { SEOBase } from "@/content/template/seo/seo";

/* ================================
   STATIC PATHS
================================ */

export async function getStaticPaths() {
  const artists = await getCollection("artists");

  return artists.map((artist) => ({
    params: { slug: artist.slug },
    props: { artist },
  }));
}

/* ================================
   DATA
================================ */

const { artist } = Astro.props;
const { Content } = await artist.render();

/* 👉 works */
const works = await getCollection("works");

const artistWorks = works.filter(
  (work) => work.data.artist === artist.slug
);

const galleryWorks = artistWorks.map((w) => ({
  title: w.data.title ?? undefined,
  image: w.data.image,
  slug: w.slug,
  alt: w.data.title ?? artist.data.title ?? "Artwork",
}));

/* 👉 sketchbooks */
const sketchbooks = await getCollection("sketchbooks");

const artistSketchbooks = sketchbooks
  .filter(
    (book) =>
      book.data.author === artist.slug &&
      book.data.published === true
  )
  .sort((a, b) => b.data.year - a.data.year);

const sketchbookCards = artistSketchbooks.map((b) => ({
  title: b.data.title,
  slug: b.slug,
  cover: `/images/sketchbooks/${b.slug}/${b.data.cover}`,
  year: b.data.year,
  isAvailable: b.data.format?.digital ?? false,
}));

/* ================================
   SEO
================================ */

const pageSEO = {
  title: artist.data.title,
  description: `Works by ${artist.data.title}`,
};
---

<InternalLayout
  baseSEO={SEOBase}
  pageSEO={pageSEO}
  navItems={mainNav}
  footerSections={footerNav}
  footerMeta={footerMeta}
  logo={BrandLogo}
>
  <section class="section">
    <div class="container flow">

  {/* 👉 HEADER */}
  <header class="hero-header">

    <div class="hero-header__left">
      <h1>{artist.data.title}</h1>

      <div class="artist-meta">

        {artist.data.style && (
          <span class="style">
            {artist.data.style}
          </span>
        )}

        {artist.data.instagram && (
          <a
            href={`https://instagram.com/${artist.data.instagram}`}
            target="_blank"
            rel="noopener noreferrer"
            class="instagram"
          >
            @{artist.data.instagram}
          </a>
        )}

      </div>
    </div>

    <div class="hero-header__right">
      <button class="hero-cta" data-scroll-to-rsvp>
        Get new sketchbooks
      </button>
    </div>

  </header>

      {/* 👉 BIO */}
      <Content />

    {/* 👉 SKETCHBOOKS */}
    {sketchbookCards.length > 0 && (
      <section class="sketchbooks-section flow">
        <h2>Sketchbooks</h2>

        <CardGrid>
          {sketchbookCards.map((book) => (
            <CardGridItem
              title={book.title}
              href={`/sketchbooks/${book.slug}`}
              text={book.year ? `${book.year}` : ""}
              buttonLabel=""
            />
          ))}
        </CardGrid>
      </section>
    )}

      {/* 👉 WORKS */}
      {galleryWorks.length > 0 && (
        <section class="gallery-section flow">
          <h2>Works</h2>
          <Gallery works={galleryWorks} />
        </section>
      )}

    </div>
  </section>

{/* ================================
   FOLLOW ARTIST CTA
================================ */}

<section class="section" id="rsvp">
  <div class="container">
    <div class="rsvp">

      <div class="rsvp__header">
        <h2 class="rsvp__title">
          Get new sketchbooks
        </h2>
      </div>

      <div class="rsvp__body">

        <p class="rsvp__note">
          Get new sketchbooks from this artist as soon as they’re published.
        </p>

        <div id="mlb2-39458049" class="rsvp__form ml-subscribe-form ml-subscribe-form-39458049">

          {/* 👉 ВАЖНО: row-form */}
          <div class="row-form">

            <form
              class="ml-block-form"
              action="https://assets.mailerlite.com/jsonp/1909692/forms/183874219513218877/subscribe"
              method="post"
            >
              <input
                type="email"
                name="fields[email]"
                placeholder="your email"
                required
                class="rsvp__input"
                autocomplete="email"
              />

              {/* 👉 передаём artist */}
              <input
                type="hidden"
                name="fields[artist]"
                value={artist.slug}
              />

              <button type="submit" class="rsvp__button">
                Follow this artist
              </button>

              <input type="hidden" name="ml-submit" value="1" />
              <input type="hidden" name="anticsrf" value="true" />
            </form>

          </div>

          {/* 👉 ВАЖНО: row-success */}
          <div class="row-success rsvp__success">
            <h4 class="rsvp__success-title">You're in ✨</h4>
            <p class="rsvp__success-text">
              We’ll send you new sketchbooks from this artist
            </p>
          </div>

        </div>

      </div>

    </div>
  </div>
</section>

</InternalLayout>

<style>
/* ================================
   HEADER
================================ */

.header {
  margin-bottom: 24px;
}

.artist-meta {
  display: flex;
  gap: 12px;
  align-items: center;

  font-size: 14px;
  opacity: 0.7;
}

/* ================================
   STYLE TAG
================================ */

.style {
  padding: 2px 8px;
  border-radius: 6px;

  background: rgba(0, 0, 0, 0.05);
}

/* ================================
   INSTAGRAM
================================ */

.instagram {
  text-decoration: none;
  color: inherit;

  border-bottom: 1px solid transparent;
}

.instagram:hover {
  border-color: currentColor;
}

/* ================================
   BIO
================================ */

.bio {
  opacity: 0.7;
  max-width: 600px;
}

/* ================================
   SKETCHBOOKS
================================ */

.sketchbooks-section {
  margin-top: 40px;
}

/* ================================
   GALLERY
================================ */

.gallery-section {
  margin-top: 40px;
}


</style>

<script is:inline>
  function ml_webform_success_39458049() {
    const container = document.getElementById('mlb2-39458049');

    if (container instanceof HTMLElement) {
      container.classList.add('is-success');
    }
  }
</script>

<script
  is:inline
  src="https://groot.mailerlite.com/js/w/webforms.min.js"
></script>

<script is:inline>
  document.querySelectorAll('[data-scroll-to-rsvp]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const el = document.getElementById('rsvp');
      if (el) {
        el.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    });
  });
</script>
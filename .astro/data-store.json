[["Map",1,2,9,10,61,62],"meta::meta",["Map",3,4,5,6,7,8],"astro-version","5.18.1","content-config-digest","29eed14dac36d27b","astro-config-digest","{\"root\":{},\"srcDir\":{},\"publicDir\":{},\"outDir\":{},\"cacheDir\":{},\"site\":\"https://vedana.tech\",\"compressHTML\":true,\"base\":\"/\",\"trailingSlash\":\"ignore\",\"output\":\"static\",\"scopedStyleStrategy\":\"attribute\",\"build\":{\"format\":\"directory\",\"client\":{},\"server\":{},\"assets\":\"_astro\",\"serverEntry\":\"entry.mjs\",\"redirects\":true,\"inlineStylesheets\":\"auto\",\"concurrency\":1},\"server\":{\"open\":false,\"host\":false,\"port\":4321,\"streaming\":true,\"allowedHosts\":[]},\"redirects\":{},\"image\":{\"endpoint\":{\"route\":\"/_image\"},\"service\":{\"entrypoint\":\"astro/assets/services/sharp\",\"config\":{}},\"domains\":[],\"remotePatterns\":[],\"responsiveStyles\":false},\"devToolbar\":{\"enabled\":true},\"markdown\":{\"syntaxHighlight\":{\"type\":\"shiki\",\"excludeLangs\":[\"math\"]},\"shikiConfig\":{\"langs\":[],\"langAlias\":{},\"theme\":\"github-dark\",\"themes\":{},\"wrap\":false,\"transformers\":[]},\"remarkPlugins\":[],\"rehypePlugins\":[],\"remarkRehype\":{},\"gfm\":true,\"smartypants\":true},\"security\":{\"checkOrigin\":true,\"allowedDomains\":[],\"actionBodySizeLimit\":1048576},\"env\":{\"schema\":{},\"validateSecrets\":false},\"experimental\":{\"clientPrerender\":false,\"contentIntellisense\":false,\"headingIdCompat\":false,\"preserveScriptOrder\":false,\"liveContentCollections\":false,\"csp\":false,\"staticImportMetaEnv\":false,\"chromeDevtoolsWorkspace\":false,\"failOnPrerenderConflict\":false,\"svgo\":false},\"legacy\":{\"collections\":false}}","artists",["Map",11,12,27,28,45,46],"beliaeva-ekaterina",{"id":11,"data":13,"body":15,"filePath":16,"digest":17,"rendered":18,"legacyId":26},{"title":14},"Ekaterina Beliaeva","Van Gogh created over 2,000 artworks...","src/content/artists/beliaeva-ekaterina.md","283d20a98b75b09d",{"html":19,"metadata":20},"\u003Cp>Van Gogh created over 2,000 artworks…\u003C/p>",{"headings":21,"localImagePaths":22,"remoteImagePaths":23,"frontmatter":24,"imagePaths":25},[],[],[],{"title":14},[],"beliaeva-ekaterina.md","poliakova-ekaterina",{"id":27,"data":29,"body":33,"filePath":34,"digest":35,"rendered":36,"legacyId":44},{"title":30,"instagram":31,"style":32},"Ekaterina Poliakova","katherine.poliakova","naive, mixed media","I have two callings: psychology and art. I’ve been drawing my whole life, but I started taking it seriously about seven years ago.\n\nMy work captures fleeting glimpses into imagined worlds – worlds that resemble our own, yet carry a subtle sense of duality and magic.\n\nI work with watercolor, gouache, pencils, acrylic, and digital media. Sometimes I also use ink, oil pastels, and markers. I’m deeply drawn to texture: watercolor for its transparency and fluid blending into paper, gouache for its rich matte finish and density, and pencils for their ability to build layers and create precise accents.\n\nI’m inspired by myths, fairy tales, and unexpected combinations. I love color for what it is — not as a concept, but as something that exists on its own.\n\nArtists I feel close to include Petrov-Vodkin, Matisse, Bruegel the Younger, and Bilibin.\n\n*Why sketchbooks?*\n\nOver time, I’ve filled quite a few of them — and unlike finished works, sketchbooks are rarely seen. For me, a sketchbook is like a friend: a space to think, to ask questions. At the same time, it’s a story.\nAnd I want to share that story.","src/content/artists/poliakova-ekaterina.md","b70fc8d1b7eff3fb",{"html":37,"metadata":38},"\u003Cp>I have two callings: psychology and art. I’ve been drawing my whole life, but I started taking it seriously about seven years ago.\u003C/p>\n\u003Cp>My work captures fleeting glimpses into imagined worlds – worlds that resemble our own, yet carry a subtle sense of duality and magic.\u003C/p>\n\u003Cp>I work with watercolor, gouache, pencils, acrylic, and digital media. Sometimes I also use ink, oil pastels, and markers. I’m deeply drawn to texture: watercolor for its transparency and fluid blending into paper, gouache for its rich matte finish and density, and pencils for their ability to build layers and create precise accents.\u003C/p>\n\u003Cp>I’m inspired by myths, fairy tales, and unexpected combinations. I love color for what it is — not as a concept, but as something that exists on its own.\u003C/p>\n\u003Cp>Artists I feel close to include Petrov-Vodkin, Matisse, Bruegel the Younger, and Bilibin.\u003C/p>\n\u003Cp>\u003Cem>Why sketchbooks?\u003C/em>\u003C/p>\n\u003Cp>Over time, I’ve filled quite a few of them — and unlike finished works, sketchbooks are rarely seen. For me, a sketchbook is like a friend: a space to think, to ask questions. At the same time, it’s a story.\nAnd I want to share that story.\u003C/p>",{"headings":39,"localImagePaths":40,"remoteImagePaths":41,"frontmatter":42,"imagePaths":43},[],[],[],{"title":30,"instagram":31,"style":32},[],"poliakova-ekaterina.md","tatarinova-olga",{"id":45,"data":47,"body":49,"filePath":50,"digest":51,"rendered":52,"legacyId":60},{"title":48},"Olga Tatarinova","By day I work in IT, by night I draw.\n\nMy favorite sketchbook is dedicated to Tbilisi – a series of 20 pencil drawings. I also create sketchbooks about places I love.","src/content/artists/tatarinova-olga.md","9e978c7710b3b098",{"html":53,"metadata":54},"\u003Cp>By day I work in IT, by night I draw.\u003C/p>\n\u003Cp>My favorite sketchbook is dedicated to Tbilisi – a series of 20 pencil drawings. I also create sketchbooks about places I love.\u003C/p>",{"headings":55,"localImagePaths":56,"remoteImagePaths":57,"frontmatter":58,"imagePaths":59},[],[],[],{"title":48},[],"tatarinova-olga.md","works",["Map",63,64,78,79,92,93,106,107,120,121,134,135,148,149,162,163,176,177,190,191,204,205,218,219],"poliakova-ekaterina-1",{"id":63,"data":65,"filePath":67,"digest":68,"rendered":69,"legacyId":77},{"artist":27,"image":66},"/images/works/poliako